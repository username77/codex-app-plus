{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Codex App Plus",
  "windows": ["main"],
  "permissions": ["core:default", "dialog:allow-open", "dialog:allow-confirm", "notification:default", "process:default", "updater:default"],
  "commands": {
    "allow": [
      "app_server_start",
      "app_server_stop",
      "app_server_restart",
      "rpc_request",
      "rpc_notify",
      "rpc_cancel",
      "server_request_resolve",
      "app_set_window_theme",
      "app_control_window",
      "app_open_external",
      "app_open_workspace",
      "app_open_codex_config_toml",
      "app_read_workspace_state",
      "app_write_workspace_state",
      "app_read_proxy_settings",
      "app_write_proxy_settings",
      "app_show_notification",
      "app_show_context_menu",
      "app_import_official_data",
      "terminal_create_session",
      "terminal_write",
      "terminal_resize",
      "terminal_close_session"
    ],
    "deny": []
  }
}
